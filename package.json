    "browserslist": [
        ">0.2%",
        "not dead",
        "not ie <= 11",
        "not op_mini all"
    ],
    "lint-staged": {
        "src/app/**/*.ts?(x)": "eslint --cache --fix",
        "*.css": "stylelint --fix",
        "src/app/**/*.{ts,tsx,js,jsx,css}": "prettier --write"
    },
